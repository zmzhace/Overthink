{
  "name": "overthink-browser",
  "displayName": "Overthink",
  "version": "0.1.0",
  "description": "Chromium-based desktop browser for thinking past the page",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc --noEmit && node scripts/build.mjs",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win nsis",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "lucide-react": "^0.468.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.overthink.browser",
    "productName": "Overthink",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "packageManager": "pnpm@8.15.4"
}
